FIREBASE_SENSOR_PATH=sensor
OPENWEATHER_API_KEY=your_openweather_api_key
DEFAULT_WEATHER_CITY=Chennai
PYTHON_PATH=python3
DISEASE_INFERENCE_ENGINE=onnx
